# Configurazione Web Service Deduzioni Trasferta TI
# Copiare questo file in .env e personalizzare i valori.
# Il file .env NON va mai committato nel repository.

# Anno fiscale di default
DEFAULT_FISCAL_YEAR=2026

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API Key — se vuoto, accesso libero; in produzione impostare un valore sicuro:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Rate limiting — richieste massime per minuto per IP
RATE_LIMIT_PER_MINUTE=30

# CORS — origini ammesse (separate da virgola)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Dimensione massima body in bytes (default 1 MB)
MAX_BODY_SIZE_BYTES=1048576
