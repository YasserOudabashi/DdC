# Configurazione Web Service Deduzioni Trasferta TI
# Copiare questo file in .env e personalizzare i valori.
# Il file .env NON va mai committato nel repository.

# Anno fiscale di default
DEFAULT_FISCAL_YEAR=2026

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# API Key — se vuoto, accesso libero; in produzione impostare un valore sicuro:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=

# Rate limiting — richieste massime per minuto per IP
RATE_LIMIT_PER_MINUTE=30

# CORS — NON usare * in produzione! Esempio: https://tuo-dominio.ch
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Dimensione massima body in bytes (default 1 MB)
MAX_BODY_SIZE_BYTES=1048576

# Documentazione API (Swagger UI e ReDoc) — false in produzione
DOCS_ENABLED=false

# Proxy — IP del reverse proxy (separati da virgola, es: 127.0.0.1); vuoto = connessione diretta
TRUSTED_PROXIES=  # IP del reverse proxy, es: 127.0.0.1

# Nominatim — email per User-Agent (richiesta dalla policy di utilizzo OSM)
NOMINATIM_CONTACT_EMAIL=tua@email.com  # per User-Agent Nominatim
